/* ════════════════════════════════════════════════════════════
   RELATÓRIOS
   ════════════════════════════════════════════════════════════ */
void barra_progresso(double pct, int largura) {
    int preenchido = (int)(pct / 100.0 * largura);
    if (preenchido > largura) preenchido = largura;
    printf("  [");
    for (int i = 0; i < largura; i++)
        printf(i < preenchido ? "█" : "░");
    printf("] %.1f%%\n", pct);
}

void relatorio_meta_vs_realizado(void) {
    cabecalho("Meta vs. Realizado");
    int mes, ano;
    printf("  Mês: "); scanf("%d", &mes);
    printf("  Ano: "); scanf("%d", &ano);

    /* Busca meta */
    Meta *m = NULL;
    for (int i = 0; i < n_metas; i++) {
        if (metas[i].mes == mes && metas[i].ano == ano) {
            m = &metas[i]; break;
        }
    }

    /* Calcula realizado */
    double faturamento = 0;
    int    num_vendas  = 0;
    char   filtro[12];
    sprintf(filtro, "/%02d/%04d", mes, ano);

    for (int i = 0; i < n_vendas; i++) {
        if (strstr(vendas[i].data, filtro)) {
            faturamento += vendas[i].total;
            num_vendas++;
        }
    }
    double ticket = num_vendas > 0 ? faturamento / num_vendas : 0;

    printf("\n  ══════ DESEMPENHO %02d/%04d ══════\n\n", mes, ano);
    printf("  Faturamento Realizado : R$ %10.2f\n", faturamento);
    printf("  Nº de Vendas          : %d\n", num_vendas);
    printf("  Ticket Médio          : R$ %10.2f\n", ticket);

    if (m) {
        printf("\n  ── Comparativo com Meta ──\n\n");

        double pct_fat = m->meta_faturamento > 0
                         ? faturamento / m->meta_faturamento * 100 : 0;
        double pct_vnd = m->meta_num_vendas > 0
                         ? (double)num_vendas / m->meta_num_vendas * 100 : 0;
        double pct_tkt = m->meta_ticket_medio > 0
                         ? ticket / m->meta_ticket_medio * 100 : 0;

        printf("  Faturamento (meta R$ %.2f):\n", m->meta_faturamento);
        barra_progresso(pct_fat, 30);

        printf("  Nº Vendas (meta %d):\n", m->meta_num_vendas);
        barra_progresso(pct_vnd, 30);

        printf("  Ticket Médio (meta R$ %.2f):\n", m->meta_ticket_medio);
        barra_progresso(pct_tkt, 30);

        double pct_geral = (pct_fat + pct_vnd + pct_tkt) / 3.0;
        printf("\n  ⭐ Desempenho geral do mês: %.1f%%\n", pct_geral);
        if (pct_geral >= 100) printf("  🏆 Meta ATINGIDA! Parabéns!\n");
        else if (pct_geral >= 75) printf("  📈 Bom desempenho! Falta pouco!\n");
        else if (pct_geral >= 50) printf("  ⚠️  Desempenho mediano. Reforçar esforços.\n");
        else printf("  🔴 Desempenho abaixo do esperado.\n");
    } else {
        printf("\n  (Meta não definida para este mês. Use o menu de Metas.)\n");
    }
    pausar();
}

void relatorio_mensal(void) {
    cabecalho("Relatório Mensal");
    int mes, ano;
    printf("  Mês: "); scanf("%d", &mes);
    printf("  Ano: "); scanf("%d", &ano);

    char filtro[12];
    sprintf(filtro, "/%02d/%04d", mes, ano);

    double total = 0; int n = 0;
    printf("\n  Vendas do mês %02d/%04d:\n\n", mes, ano);
    printf("  %-10s %-20s %-15s %5s %10s\n","Data","Produto","Func.","Qtd","Total");
    printf("  %s\n","─────────────────────────────────────────────────────────");

    for (int i = 0; i < n_vendas; i++) {
        Venda *v = &vendas[i];
        if (strstr(v->data, filtro)) {
            printf("  %-10s %-20s %-15s %5d  R$%7.2f\n",
                   v->data, v->produto, v->funcionario,
                   v->quantidade, v->total);
            total += v->total; n++;
        }
    }
    if (n == 0) printf("  Nenhuma venda neste mês.\n");
    else {
        printf("  %s\n","─────────────────────────────────────────────────────────");
        printf("  Total de vendas: %d  |  Faturamento: R$ %.2f  |  Ticket médio: R$ %.2f\n",
               n, total, total / n);
    }
    pausar();
}

void relatorio_desempenho_func(void) {
    cabecalho("Desempenho por Funcionário");
    int mes, ano;
    printf("  Mês (0=todos): "); scanf("%d", &mes);
    if (mes != 0) { printf("  Ano: "); scanf("%d", &ano); }

    printf("\n  %-20s %10s %10s %12s\n","Funcionário","Vendas","Faturamento","Comissão(R$)");
    printf("  %s\n","──────────────────────────────────────────────────────");

    /* Para cada funcionário cadastrado */
    for (int fi = 0; fi < n_func; fi++) {
        double fat = 0; int cnt = 0;
        char filtro[12];
        if (mes != 0) sprintf(filtro, "/%02d/%04d", mes, ano);

        for (int vi = 0; vi < n_vendas; vi++) {
            Venda *v = &vendas[vi];
            if (strncmp(v->funcionario, funcionarios[fi].nome, MAX_NOME) == 0) {
                if (mes == 0 || strstr(v->data, filtro)) {
                    fat += v->total; cnt++;
                }
            }
        }
        double comissao = fat * funcionarios[fi].comissao_pct / 100.0;
        printf("  %-20s %10d  R$%8.2f   R$%9.2f\n",
               funcionarios[fi].nome, cnt, fat, comissao);
    }
    pausar();
}

void relatorio_produtos_mais_vendidos(void) {
    cabecalho("Produtos Mais Vendidos");

    /* Agrega por nome de produto */
    char  nomes[MAX_VENDAS][MAX_NOME];
    int   qtds[MAX_VENDAS];
    double totais[MAX_VENDAS];
    int   np = 0;

    for (int i = 0; i < n_vendas; i++) {
        int achou = 0;
        for (int j = 0; j < np; j++) {
            if (strcmp(nomes[j], vendas[i].produto) == 0) {
                qtds[j]   += vendas[i].quantidade;
                totais[j] += vendas[i].total;
                achou = 1; break;
            }
        }
        if (!achou && np < MAX_VENDAS) {
            strncpy(nomes[np], vendas[i].produto, MAX_NOME);
            qtds[np]   = vendas[i].quantidade;
            totais[np] = vendas[i].total;
            np++;
        }
    }

    /* Ordenação bolha por quantidade */
    for (int i = 0; i < np - 1; i++) {
        for (int j = 0; j < np - 1 - i; j++) {
            if (qtds[j] < qtds[j+1]) {
                int ti = qtds[j]; qtds[j] = qtds[j+1]; qtds[j+1] = ti;
                double td = totais[j]; totais[j] = totais[j+1]; totais[j+1] = td;
                char tn[MAX_NOME];
                strcpy(tn, nomes[j]); strcpy(nomes[j], nomes[j+1]); strcpy(nomes[j+1], tn);
            }
        }
    }

    printf("  %-5s %-25s %10s %14s\n","Rank","Produto","Qtd Vendida","Faturamento");
    printf("  %s\n","─────────────────────────────────────────────────────");
    int lim = np < 10 ? np : 10;
    for (int i = 0; i < lim; i++) {
        printf("  %3dº  %-25s %10d   R$%10.2f\n",
               i+1, nomes[i], qtds[i], totais[i]);
    }
    if (np == 0) printf("  Nenhuma venda registrada.\n");
    pausar();
}

