/* ════════════════════════════════════════════════════════════
   VENDAS
   ════════════════════════════════════════════════════════════ */
void registrar_venda(void) {
    if (n_vendas >= MAX_VENDAS) {
        printf("  [!] Limite de vendas atingido.\n");
        pausar(); return;
    }
    cabecalho("Registrar Nova Venda");
    Venda v;
    v.id = n_vendas + 1;
    data_hoje(v.data);

    printf("  Data [%s] (Enter p/ hoje, ou dd/mm/aaaa): ", v.data);
    char buf[20]; fgets(buf, sizeof(buf), stdin);
    if (buf[0] != '\n') {
        buf[strcspn(buf, "\n")] = '\0';
        strncpy(v.data, buf, 10);
    }

    printf("  Produto: "); fgets(v.produto, MAX_NOME, stdin);
    v.produto[strcspn(v.produto, "\n")] = '\0';

    printf("  Funcionário responsável: "); fgets(v.funcionario, MAX_NOME, stdin);
    v.funcionario[strcspn(v.funcionario, "\n")] = '\0';

    printf("  Quantidade: "); scanf("%d", &v.quantidade);
    printf("  Preço unitário (R$): "); scanf("%lf", &v.preco_unitario);
    v.total = v.quantidade * v.preco_unitario;

    vendas[n_vendas++] = v;
    salvar_vendas();

    printf("\n  ✅ Venda #%d registrada! Total: R$ %.2f\n", v.id, v.total);
    pausar();
}

void listar_vendas(void) {
    cabecalho("Todas as Vendas");
    if (n_vendas == 0) { printf("  Nenhuma venda registrada.\n"); pausar(); return; }
    printf("  %-4s %-10s %-20s %-15s %5s %10s %10s\n",
           "ID","Data","Produto","Funcionário","Qtd","Unit.","Total");
    printf("  %s\n", "─────────────────────────────────────────────────────────────────────");
    for (int i = 0; i < n_vendas; i++) {
        Venda *v = &vendas[i];
        printf("  %-4d %-10s %-20s %-15s %5d  R$%7.2f  R$%8.2f\n",
               v->id, v->data, v->produto, v->funcionario,
               v->quantidade, v->preco_unitario, v->total);
    }
    pausar();
}

void menu_vendas(void) {
    int op;
    do {
        cabecalho("Menu de Vendas");
        printf("  [1] Registrar venda\n");
        printf("  [2] Listar todas as vendas\n");
        printf("  [0] Voltar\n\n");
        printf("  Opcao: "); scanf("%d", &op);
        switch (op) {
            case 1: registrar_venda(); break;
            case 2: listar_vendas();   break;
        }
    } while (op != 0);
}

/* ════════════════════════════════════════════════════════════
   METAS
   ════════════════════════════════════════════════════════════ */
void definir_meta(void) {
    if (n_metas >= 24) { printf("  Limite de metas atingido.\n"); pausar(); return; }
    cabecalho("Definir Meta Mensal");
    Meta m;
    printf("  Mês (1-12): ");   scanf("%d", &m.mes);
    printf("  Ano (ex: 2025): "); scanf("%d", &m.ano);

    /* verifica se já existe */
    for (int i = 0; i < n_metas; i++) {
        if (metas[i].mes == m.mes && metas[i].ano == m.ano) {
            printf("  Já existe meta para %02d/%04d. Sobrescrevendo...\n",
                   m.mes, m.ano);
            printf("  Faturamento meta (R$): "); scanf("%lf", &m.meta_faturamento);
            printf("  Ticket médio meta (R$): "); scanf("%lf", &m.meta_ticket_medio);
            printf("  Nº de vendas meta: ");     scanf("%d",  &m.meta_num_vendas);
            metas[i] = m;
            salvar_metas();
            printf("  ✅ Meta atualizada!\n");
            pausar(); return;
        }
    }
    printf("  Faturamento meta (R$): "); scanf("%lf", &m.meta_faturamento);
    printf("  Ticket médio meta (R$): "); scanf("%lf", &m.meta_ticket_medio);
    printf("  Nº de vendas meta: ");     scanf("%d",  &m.meta_num_vendas);
    metas[n_metas++] = m;
    salvar_metas();
    printf("  ✅ Meta definida!\n");
    pausar();
}

void ver_metas(void) {
    cabecalho("Metas Cadastradas");
    if (n_metas == 0) { printf("  Nenhuma meta definida.\n"); pausar(); return; }
    printf("  %-10s %18s %18s %15s\n",
           "Mês/Ano","Faturamento(R$)","Ticket Médio(R$)","Nº Vendas");
    printf("  %s\n","─────────────────────────────────────────────────────────────");
    for (int i = 0; i < n_metas; i++) {
        Meta *m = &metas[i];
        printf("  %02d/%04d        %15.2f     %15.2f     %10d\n",
               m->mes, m->ano, m->meta_faturamento,
               m->meta_ticket_medio, m->meta_num_vendas);
    }
    pausar();
}

void menu_metas(void) {
    int op;
    do {
        cabecalho("Menu de Metas");
        printf("  [1] Definir meta mensal\n");
        printf("  [2] Ver metas cadastradas\n");
        printf("  [0] Voltar\n\n");
