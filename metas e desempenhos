void cadastrar_produto(void) {
    if (n_produtos >= MAX_PRODUTOS) { printf("  Limite atingido.\n"); pausar(); return; }
    cabecalho("Cadastrar Produto");
    Produto p;
    p.id = n_produtos + 1;
    printf("  Nome do produto: "); fgets(p.nome, MAX_NOME, stdin); fgets(p.nome, MAX_NOME, stdin);
    p.nome[strcspn(p.nome, "\n")] = '\0';
    printf("  Categoria: ");       fgets(p.categoria, MAX_NOME, stdin);
    p.categoria[strcspn(p.categoria, "\n")] = '\0';
    printf("  Preço (R$): ");      scanf("%lf", &p.preco);
    printf("  Estoque inicial: "); scanf("%d",  &p.estoque);
    produtos[n_produtos++] = p;
    salvar_produtos();
    printf("  ✅ Produto cadastrado (ID: %d)!\n", p.id);
    pausar();
}

void listar_produtos(void) {
    cabecalho("Produtos Cadastrados");
    if (n_produtos == 0) { printf("  Nenhum produto.\n"); pausar(); return; }
    printf("  %-4s %-25s %-15s %10s %8s\n","ID","Nome","Categoria","Preço","Estoque");
    printf("  %s\n","─────────────────────────────────────────────────");
    for (int i = 0; i < n_produtos; i++) {
        Produto *p = &produtos[i];
        printf("  %-4d %-25s %-15s R$%7.2f %7d\n",
               p->id, p->nome, p->categoria, p->preco, p->estoque);
    }
    pausar();
}

void atualizar_estoque(void) {
    cabecalho("Atualizar Estoque");
    listar_produtos();
    int id, qtd;
    printf("  ID do produto: "); scanf("%d", &id);
    printf("  Adicionar (+) ou remover (-) quantidade: "); scanf("%d", &qtd);
    for (int i = 0; i < n_produtos; i++) {
        if (produtos[i].id == id) {
            produtos[i].estoque += qtd;
            if (produtos[i].estoque < 0) produtos[i].estoque = 0;
            salvar_produtos();
            printf("  ✅ Estoque atualizado: %d unidades.\n", produtos[i].estoque);
            pausar(); return;
        }
    }
    printf("  Produto não encontrado.\n"); pausar();
}

