#include <string.h>
#include <math.h>
#include <time.h>

/* ── Constantes ──────────────────────────────────────────── */
#define MAX_VENDAS      500
#define MAX_PRODUTOS    100
#define MAX_FUNCIONARIOS 20
#define MAX_NOME        60

#define ARQ_VENDAS       "vendas.dat"
#define ARQ_METAS        "metas.dat"
#define ARQ_PRODUTOS     "produtos.dat"
#define ARQ_FUNCIONARIOS "funcionarios.dat"

/* ── Estruturas ──────────────────────────────────────────── */
typedef struct {
    int    id;
    char   data[11];          /* dd/mm/aaaa */
    char   produto[MAX_NOME];
    char   funcionario[MAX_NOME];
    int    quantidade;
    double preco_unitario;
    double total;
} Venda;

typedef struct {
    int    mes;               /* 1-12 */
    int    ano;
    double meta_faturamento;
    double meta_ticket_medio;
    int    meta_num_vendas;
} Meta;

typedef struct {
    int  id;
    char nome[MAX_NOME];
    char categoria[MAX_NOME];
    double preco;
    int  estoque;
} Produto;

typedef struct {
    int  id;
    char nome[MAX_NOME];
    char cargo[MAX_NOME];
    double comissao_pct;      /* % sobre vendas */
} Funcionario;

/* ── Globais ─────────────────────────────────────────────── */
Venda       vendas[MAX_VENDAS];
Produto     produtos[MAX_PRODUTOS];
Funcionario funcionarios[MAX_FUNCIONARIOS];
Meta        metas[24];          /* até 2 anos de metas */

int n_vendas = 0, n_produtos = 0, n_func = 0, n_metas = 0;

