void limpar_tela(void) {
#ifdef _WIN32
    system("cls");
#else
    system("clear");
#endif
}

void pausar(void) {
    printf("\n  Pressione ENTER para continuar...");
    getchar(); getchar();
}

void cabecalho(const char *titulo) {
    limpar_tela();
    printf("  ╔══════════════════════════════════════════════╗\n");
    printf("  ║   🛒  MERCADINHO - METAS & DESEMPENHO        ║\n");
    printf("  ╠══════════════════════════════════════════════╣\n");
    printf("  ║  %-44s║\n", titulo);
    printf("  ╚══════════════════════════════════════════════╝\n\n");
}

void data_hoje(char *buf) {
    time_t t = time(NULL);
    struct tm *tm = localtime(&t);
    sprintf(buf, "%02d/%02d/%04d", tm->tm_mday, tm->tm_mon + 1,
            tm->tm_year + 1900);
}

/* ════════════════════════════════════════════════════════════
   PERSISTÊNCIA
   ════════════════════════════════════════════════════════════ */
void salvar_vendas(void) {
    FILE *f = fopen(ARQ_VENDAS, "wb");
    if (!f) { perror("Erro ao salvar vendas"); return; }
    fwrite(&n_vendas, sizeof(int), 1, f);
    fwrite(vendas, sizeof(Venda), n_vendas, f);
    fclose(f);
}
void carregar_vendas(void) {
    FILE *f = fopen(ARQ_VENDAS, "rb");
    if (!f) return;
    fread(&n_vendas, sizeof(int), 1, f);
    fread(vendas, sizeof(Venda), n_vendas, f);
    fclose(f);
}
void salvar_metas(void) {
    FILE *f = fopen(ARQ_METAS, "wb");
    if (!f) return;
    fwrite(&n_metas, sizeof(int), 1, f);
    fwrite(metas, sizeof(Meta), n_metas, f);
    fclose(f);
}
void carregar_metas(void) {
    FILE *f = fopen(ARQ_METAS, "rb");
    if (!f) return;
    fread(&n_metas, sizeof(int), 1, f);
    fread(metas, sizeof(Meta), n_metas, f);
    fclose(f);
}
