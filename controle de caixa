#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <string.h>

#define MAX_HISTORICO 100

// ── Estrutura de cada movimentação ──
typedef struct {
    char tipo[10];        // "VENDA" ou "DESPESA"
    char produto[50];     // nome do produto
    float valor;
    char horario[30];
} Movimentacao;

// ── Função para imprimir linha separadora ──
void linha() {
    printf("=====================================\n");
}

// ── Função para imprimir o histórico ──
void exibirHistorico(Movimentacao hist[], int total) {
    if (total == 0) {
        printf("Nenhuma movimentacao registrada.\n");
        return;
    }

    printf("\n");
    linha();
    printf("        HISTORICO DE MOVIMENTACOES    \n");
    linha();
    printf("%-3s %-10s %-20s %-10s %s\n",
           "#", "TIPO", "PRODUTO", "VALOR", "HORARIO");
    printf("-------------------------------------\n");

    for (int i = 0; i < total; i++) {
        printf("%-3d %-10s %-20s R$%-8.2f %s\n",
               i + 1,
               hist[i].tipo,
               hist[i].produto,
               hist[i].valor,
               hist[i].horario);
    }
    linha();
}

int main() {
    float saldoA, totalVend = 0, totalDesp = 0;
    int caixa;

    Movimentacao historico[MAX_HISTORICO];
    int totalMov = 0;  // contador de movimentações

    // ── Abertura ──
    time_t currentTime = time(NULL);
    linha();
    printf("        CONTROLE DE CAIXA            \n");
    linha();
    printf("Abertura: %s", ctime(&currentTime));
    printf("-------------------------------------\n");
    printf("Saldo inicial: R$ ");
    scanf("%f", &saldoA);

    do {
        float saldoAtual = saldoA + totalVend - totalDesp;

        printf("\n");
        linha();
        printf("  Saldo Atual: R$ %.2f\n", saldoAtual);
        linha();
        printf("1. Registrar Venda\n");
        printf("2. Registrar Despesa\n");
        printf("3. Ver Resumo\n");
        printf("4. Ver Historico\n");
        printf("0. Fechar Caixa\n");
        printf("-------------------------------------\n");
        printf("Opcao: ");
        scanf("%d", &caixa);

        switch (caixa) {

            case 1: {
                char produto[50];
                float valor;

                printf("Nome do produto: ");
                scanf(" %[^\n]", produto);
                printf("Valor da venda: R$ ");
                scanf("%f", &valor);

                totalVend += valor;

                // salva no histórico
                time_t t = time(NULL);
                struct tm *tm_info = localtime(&t);
                Movimentacao m;
                strcpy(m.tipo, "VENDA");
                strcpy(m.produto, produto);
                m.valor = valor;
                strftime(m.horario, 30, "%H:%M:%S", tm_info);
                historico[totalMov++] = m;

                printf("-------------------------------------\n");
                printf("Venda registrada!\n");
                printf("Produto : %s\n", produto);
                printf("Valor   : R$ %.2f\n", valor);
                printf("Total vendas hoje: R$ %.2f\n", totalVend);
                break;
            }

            case 2: {
                char produto[50];
                float valor;

                printf("Descricao da despesa: ");
                scanf(" %[^\n]", produto);
                printf("Valor da despesa: R$ ");
                scanf("%f", &valor);

                totalDesp += valor;

                // salva no histórico
                time_t t = time(NULL);
                struct tm *tm_info = localtime(&t);
                Movimentacao m;
                strcpy(m.tipo, "DESPESA");
                strcpy(m.produto, produto);
                m.valor = valor;
                strftime(m.horario, 30, "%H:%M:%S", tm_info);
                historico[totalMov++] = m;

                printf("-------------------------------------\n");
                printf("Despesa registrada!\n");
                printf("Descricao: %s\n", produto);
                printf("Valor    : R$ %.2f\n", valor);
                printf("Total despesas hoje: R$ %.2f\n", totalDesp);
                break;
            }

            case 3: {
                float saldoF = saldoA + totalVend - totalDesp;
                printf("\n");
                linha();
                printf("           RESUMO DO CAIXA           \n");
                linha();
                printf("Saldo inicial  :   R$ %.2f\n", saldoA);
                printf("Total vendas   : + R$ %.2f\n", totalVend);
                printf("Total despesas : - R$ %.2f\n", totalDesp);
                printf("-------------------------------------\n");
                printf("Saldo atual    :   R$ %.2f\n", saldoF);
                linha();
                printf("Movimentacoes registradas: %d\n", totalMov);

                if (saldoF < 0)
                    printf("!! ATENCAO: Saldo negativo !!\n");
                break;
            }

            case 4:
                exibirHistorico(historico, totalMov);
                break;

            case 0: {
                float saldoF = saldoA + totalVend - totalDesp;
                time_t closeTime = time(NULL);

                exibirHistorico(historico, totalMov);

                printf("\n");
                linha();
                printf("        FECHAMENTO DE CAIXA          \n");
                linha();
                printf("Fechamento: %s", ctime(&closeTime));
                printf("-------------------------------------\n");
                printf("Saldo inicial  :   R$ %.2f\n", saldoA);
                printf("Total vendas   : + R$ %.2f\n", totalVend);
                printf("Total despesas : - R$ %.2f\n", totalDesp);
                printf("-------------------------------------\n");
                printf("Saldo final    :   R$ %.2f\n", saldoF);
                linha();

                if (saldoF < 0)
                    printf("!! ATENCAO: Caixa fechado no negativo !!\n");
                else
                    printf("Caixa fechado com sucesso. Ate logo!\n");
                break;
            }

            default:
                printf("Opcao invalida. Tente novamente.\n");
                break;
        }

    } while (caixa != 0);

    system("pause");
    return 0;
}
